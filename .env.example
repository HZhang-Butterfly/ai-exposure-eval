# ─────────────────────────────────────────────────────────────────────────────
# Job Evaluation Pipeline — environment variable overrides
#
# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.
#
# Priority: CLI args > env vars (.env) > pipeline_config.json > built-in defaults
# ─────────────────────────────────────────────────────────────────────────────

# Server
EVAL_SERVER_IP=YOUR_SERVER_IP         # e.g. 192.168.1.100 or localhost
EVAL_SERVER_PORT=8000                 # vLLM default; Ollama uses 11434

# Model names (use different ports if teacher/student are on separate servers)
EVAL_TEACHER_MODEL=YOUR_MODEL_NAME    # e.g. meta-llama/Llama-3-8B-Instruct
EVAL_STUDENT_MODEL=YOUR_MODEL_NAME
EVAL_JUDGE_MODEL=YOUR_MODEL_NAME

# Optional: separate teacher/student/judge servers
# EVAL_TEACHER_PORT=8000
# EVAL_STUDENT_PORT=8001
# EVAL_JUDGE_PORT=8002
